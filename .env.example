# ----------------------------------------------------------------------------
# AeroQuote environment variables
# Copy this file to `.env` and fill in real values.
# ----------------------------------------------------------------------------

# --- Database (Supabase Postgres) -------------------------------------------
# Connection string used by Prisma at runtime (pooled, port 6543 recommended).
# In Supabase: Project Settings > Database > Connection string > "Transaction" mode.
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection (port 5432) used by Prisma Migrate / introspection.
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# --- Supabase Auth / Storage (client + server) ------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# Server-only key; NEVER expose to the client. Used by storage uploads + admin tasks.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# Name of the Supabase Storage bucket for uploaded photos / spec sheets.
SUPABASE_STORAGE_BUCKET="attachments"

# --- Anthropic Claude API (server-only) -------------------------------------
ANTHROPIC_API_KEY="sk-ant-..."
# Model used for receipt reading, extraction + catalogue matching (optional —
# defaults to claude-sonnet-5). Use claude-haiku-4-5-20251001 for lower cost.
ANTHROPIC_MODEL="claude-sonnet-5"

# --- App config -------------------------------------------------------------
# Public base URL (used for shareable quote links). No trailing slash.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# VAT rate as a decimal (Philippines = 0.12). Configurable.
NEXT_PUBLIC_VAT_RATE="0.12"
# Default currency.
NEXT_PUBLIC_DEFAULT_CURRENCY="PHP"

# --- Automated client follow-ups (optional) ---------------------------------
# Resend API key — enables automatic follow-up emails. Leave unset to keep the
# scheduler in dry-run (it computes and logs but sends nothing).
RESEND_API_KEY=""
# Sender for follow-up emails. Must be an address on a domain you've verified in
# Resend (a Gmail address will NOT work).
FOLLOW_UP_FROM_EMAIL="quotes@your-domain.com"
FOLLOW_UP_FROM_NAME="AEROVENT FBM"
# Shared secret protecting the daily scheduler endpoint (/api/cron/follow-ups).
# Vercel Cron sends it automatically as a Bearer token. Without it, the endpoint
# refuses to run.
CRON_SECRET=""
