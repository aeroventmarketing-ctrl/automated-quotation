// AeroQuote — Prisma schema
// All proprietary data (catalogue, pricelist, rating curves) lives in the DB,
// never hard-coded, so it can be edited in admin screens or bulk re-imported.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  SALES
  ENGINEER
  ADMIN
}

enum Family {
  AXIAL
  CENTRIFUGAL
  PROPELLER
  TUBULAR_INLINE
  CABINET
  ACCESSORY
  SERVICE
  OTHER
}

enum InquirySource {
  EMAIL
  PHONE
  WALK_IN
  PHOTO
  OTHER
}

enum InquiryStatus {
  NEW
  DRAFTING
  QUOTED
  SENT
  WON
  LOST
}

enum InquiryItemStatus {
  PENDING
  MATCHED
  SELECTED
  REJECTED
}

enum QuotationStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENT
}

enum AttachmentKind {
  PHOTO
  SPEC_SHEET
  DRAWING
  OTHER
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      Role     @default(SALES)
  // Single letter appended to quote numbers for this sales person (e.g. "J").
  salesCode String?
  createdAt DateTime @default(now())

  inquiriesCreated   Inquiry[]   @relation("InquiryCreatedBy")
  quotationsPrepared Quotation[] @relation("QuotationPreparedBy")
  quotationsApproved Quotation[] @relation("QuotationApprovedBy")
}

model Customer {
  id          String  @id @default(cuid())
  company     String
  contactName String?
  email       String?
  phone       String?
  address     String?
  notes       String?

  inquiries Inquiry[]
}

model CatalogueItem {
  id          String  @id @default(cuid())
  family      Family
  modelCode   String  @unique
  name        String
  description String?
  sizeLabel   String?
  // specs: airflow range, static-pressure range, motor HP options, drive type, material, etc.
  specs       Json    @default("{}")
  uom         String  @default("unit")
  active      Boolean @default(true)

  priceList       PriceListEntry[]
  ratingPoints    FanRatingPoint[]
  quotationItems  QuotationItem[]

  @@index([family])
}

model PriceListEntry {
  id              String   @id @default(cuid())
  catalogueItemId String
  // size / variant this price applies to (e.g. "0.5HP-Single", matches sizeLabel)
  variantKey      String   @default("default")
  currency        String   @default("PHP")
  basePrice       Decimal  @db.Decimal(14, 2)
  // optionsJson: priced add-ons keyed by option name -> price (motor, coating, flange...)
  optionsJson     Json     @default("{}")
  effectiveDate   DateTime @default(now())
  active          Boolean  @default(true)

  catalogueItem CatalogueItem @relation(fields: [catalogueItemId], references: [id], onDelete: Cascade)

  @@index([catalogueItemId])
}

// Fan selection / sizing data. Each model has several rating points along a curve.
model FanRatingPoint {
  id                String  @id @default(cuid())
  catalogueItemId   String
  rpm               Int
  airflow_m3hr      Float
  staticPressure_pa Float
  power_kw          Float
  efficiency        Float? // 0..1

  catalogueItem CatalogueItem @relation(fields: [catalogueItemId], references: [id], onDelete: Cascade)

  @@index([catalogueItemId])
}

model Inquiry {
  id          String        @id @default(cuid())
  customerId  String
  source      InquirySource @default(OTHER)
  status      InquiryStatus @default(NEW)
  createdById String
  projectName String?
  notes       String?
  createdAt   DateTime      @default(now())

  customer    Customer       @relation(fields: [customerId], references: [id])
  createdBy   User           @relation("InquiryCreatedBy", fields: [createdById], references: [id])
  items       InquiryItem[]
  attachments Attachment[]
  quotations  Quotation[]

  @@index([status])
  @@index([customerId])
}

model InquiryItem {
  id        String            @id @default(cuid())
  inquiryId String
  rawText   String // verbatim of what the client asked for
  // parsedJson: AI-extracted { airflow, airflowUnit, pressure, pressureUnit, qty, application, modelText, ... }
  parsedJson Json             @default("{}")
  qty        Int              @default(1)
  status     InquiryItemStatus @default(PENDING)

  inquiry Inquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  @@index([inquiryId])
}

model Quotation {
  id           String          @id @default(cuid())
  inquiryId    String
  quoteNumber  String          @unique // e.g. 2026 - AFBM00000041J
  templateId   String
  status       QuotationStatus @default(DRAFT)
  // VAT presentation: INCLUSIVE (prices already include 12% VAT) or EXCLUSIVE.
  vatMode      String          @default("INCLUSIVE")
  // Optional discount percentage shown as a "LESS x% DISCOUNT" line.
  discountPct  Decimal         @db.Decimal(5, 2) @default(0)
  // Variable (red) table unit labels: { capacity, pressure, motor }. Defaults cfm / in-w.g. / Hp.
  headerUnits  Json            @default("{}")
  // Product classification from the selection workflow: { category, type, bladeType, drive }.
  classification Json          @default("{}")
  projectName  String?
  subtotal     Decimal         @db.Decimal(14, 2) @default(0)
  vat          Decimal         @db.Decimal(14, 2) @default(0)
  total        Decimal         @db.Decimal(14, 2) @default(0)
  currency     String          @default("PHP")
  validUntil   DateTime?
  preparedById String
  approvedById String?
  notes        String?
  terms        String?
  createdAt    DateTime        @default(now())

  inquiry    Inquiry           @relation(fields: [inquiryId], references: [id])
  template   QuotationTemplate @relation(fields: [templateId], references: [id])
  preparedBy User              @relation("QuotationPreparedBy", fields: [preparedById], references: [id])
  approvedBy User?             @relation("QuotationApprovedBy", fields: [approvedById], references: [id])
  items      QuotationItem[]
  purchaseRequests PurchaseRequest[]
  commission Commission?

  @@index([status])
  @@index([inquiryId])
}

model QuotationItem {
  id                  String   @id @default(cuid())
  quotationId         String
  catalogueItemId     String?
  descriptionSnapshot String
  // specsSnapshot: frozen specs so the quote never changes when the catalogue does
  specsSnapshot       Json     @default("{}")
  qty                 Int      @default(1)
  unitPrice           Decimal  @db.Decimal(14, 2)
  lineTotal           Decimal  @db.Decimal(14, 2)
  selectionNote       String? // why this model/size was chosen
  sortOrder           Int      @default(0)

  quotation     Quotation      @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  catalogueItem CatalogueItem? @relation(fields: [catalogueItemId], references: [id])

  @@index([quotationId])
}

model QuotationTemplate {
  id         String  @id @default(cuid())
  name       String
  layoutKey  String  @unique // e.g. "standard", "government", "detailed", "budgetary", "export"
  headerHtml String?
  footerHtml String?
  config     Json    @default("{}")
  active     Boolean @default(true)

  quotations Quotation[]
}

model Attachment {
  id          String         @id @default(cuid())
  inquiryId   String
  storagePath String
  kind        AttachmentKind @default(OTHER)
  createdAt   DateTime       @default(now())

  inquiry Inquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  @@index([inquiryId])
}

// Sequence helper for per-year quote numbering (AQ-YYYY-NNNN).
model QuoteCounter {
  year      Int @id
  lastValue Int @default(0)
}

/** Generic key/value app settings (e.g. the geofence/location access config). */
model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

/**
 * Purchasing chain for the order-to-delivery workflow (Phase 3, steps 8-13).
 * One row per material request escalated to purchasing. The status walks the
 * approval chain; each step stamps who did it and when.
 */
enum PurchaseRequestStatus {
  PENDING_APPROVAL // 8: purchaser prepared the list, awaiting approver
  REJECTED         // 8: approver rejected
  APPROVED         // 8 done, awaiting voucher/check
  VOUCHER_READY    // 9: voucher + check approved, awaiting buying
  PURCHASED        // 10: bought, awaiting purchaser's item check
  CHECKED          // 11: items checked, awaiting delivery to warehouse
  RECEIVED         // 13: warehouse received, awaiting plant manager
  COMPLETED        // 13: plant manager final approval
}

model PurchaseRequest {
  id            String                @id @default(cuid())
  quotationId   String
  mrfId         String? // the JSON material-request id it was escalated from
  dept          String // production department key
  items         Json                  @default("[]") // ["GI sheet 24ga x 4", ...]
  note          String?
  status        PurchaseRequestStatus @default(PENDING_APPROVAL)

  createdById   String
  createdByName String
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  // 8 — approver decision
  decidedById   String?
  decidedByName String?
  decisionNote  String?
  decidedAt     DateTime?
  // 9 — voucher / check
  voucherRef    String?
  voucherByName String?
  voucherAt     DateTime?
  // 10 — buying
  purchasedByName String?
  purchasedAt   DateTime?
  // 11 — purchaser item check
  checkedByName String?
  checkedAt     DateTime?
  // 13 — warehouse receive + plant manager final approval
  receivedByName String?
  receivedAt    DateTime?
  plantApprovedByName String?
  plantApprovedAt DateTime?

  // Purchase Order sent to the supplier (number, supplier, priced lines, EWT,
  // remarks). Null until the purchaser issues the PO.
  po            Json?

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
  @@index([status])
}

/**
 * Sales commission (Phase 7). One row per closed order: 1.5% of the order value,
 * credited to the order's salesperson and attributed to the close month.
 * Paid 15 days after that month ends.
 */
model Commission {
  id              String   @id @default(cuid())
  quotationId     String   @unique
  salespersonId   String
  salespersonName String
  orderValue      Decimal  @db.Decimal(14, 2)
  ratePct         Decimal  @db.Decimal(5, 2) @default(1.5)
  amount          Decimal  @db.Decimal(14, 2)
  salesMonth      String // "YYYY-MM" (close month)
  computedAt      DateTime @default(now())
  paid            Boolean  @default(false)
  paidAt          DateTime?
  paidByName      String?

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([salesMonth])
  @@index([salespersonId])
  @@index([paid])
}

/** Warehouse stock. Quantities are decimals so partial units (m, kg) work. */
enum StockMovementKind {
  RECEIPT    // stock in (e.g. purchased items received)
  ISSUE      // stock out (e.g. issued to production)
  ADJUSTMENT // manual correction / opening balance
}

model StockItem {
  id           String   @id @default(cuid())
  name         String
  unit         String   @default("pcs")
  category     String?
  location     String?  // warehouse bin / shelf location
  quantity     Decimal  @db.Decimal(14, 3) @default(0)
  reorderLevel Decimal  @db.Decimal(14, 3) @default(0)
  unitCost     Decimal  @db.Decimal(14, 2) @default(0) // for stock valuation
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  movements StockMovement[]

  @@index([name])
}

model StockMovement {
  id           String            @id @default(cuid())
  stockItemId  String
  kind         StockMovementKind
  delta        Decimal           @db.Decimal(14, 3)
  balanceAfter Decimal           @db.Decimal(14, 3)
  reason       String?
  byName       String
  createdAt    DateTime          @default(now())

  stockItem StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  @@index([stockItemId])
}
