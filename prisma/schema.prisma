// AeroQuote — Prisma schema
// All proprietary data (catalogue, pricelist, rating curves) lives in the DB,
// never hard-coded, so it can be edited in admin screens or bulk re-imported.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  SALES
  ENGINEER
  ADMIN
  // Sign-in-only access for staff who are neither Sales nor Engineers (e.g. an
  // Approver or Accountant) — their abilities come from their workflow roles.
  OTHER
}

enum Family {
  AXIAL
  CENTRIFUGAL
  PROPELLER
  TUBULAR_INLINE
  CABINET
  ACCESSORY
  SERVICE
  OTHER
}

enum InquirySource {
  EMAIL
  PHONE
  WALK_IN
  PHOTO
  OTHER
}

enum InquiryStatus {
  NEW
  DRAFTING
  QUOTED
  SENT
  WON
  LOST
}

enum InquiryItemStatus {
  PENDING
  MATCHED
  SELECTED
  REJECTED
}

enum QuotationStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENT
}

enum AttachmentKind {
  PHOTO
  SPEC_SHEET
  DRAWING
  OTHER
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      Role     @default(SALES)
  // Single letter appended to quote numbers for this sales person (e.g. "J").
  salesCode String?
  createdAt DateTime @default(now())

  inquiriesCreated   Inquiry[]   @relation("InquiryCreatedBy")
  quotationsPrepared Quotation[] @relation("QuotationPreparedBy")
  quotationsApproved Quotation[] @relation("QuotationApprovedBy")
}

model Customer {
  id          String  @id @default(cuid())
  company     String
  contactName String?
  email       String?
  phone       String?
  address     String?
  notes       String?

  inquiries Inquiry[]
}

model CatalogueItem {
  id          String  @id @default(cuid())
  family      Family
  modelCode   String  @unique
  name        String
  description String?
  sizeLabel   String?
  // specs: airflow range, static-pressure range, motor HP options, drive type, material, etc.
  specs       Json    @default("{}")
  uom         String  @default("unit")
  active      Boolean @default(true)

  priceList       PriceListEntry[]
  ratingPoints    FanRatingPoint[]
  quotationItems  QuotationItem[]

  @@index([family])
}

model PriceListEntry {
  id              String   @id @default(cuid())
  catalogueItemId String
  // size / variant this price applies to (e.g. "0.5HP-Single", matches sizeLabel)
  variantKey      String   @default("default")
  currency        String   @default("PHP")
  basePrice       Decimal  @db.Decimal(14, 2)
  // optionsJson: priced add-ons keyed by option name -> price (motor, coating, flange...)
  optionsJson     Json     @default("{}")
  effectiveDate   DateTime @default(now())
  active          Boolean  @default(true)

  catalogueItem CatalogueItem @relation(fields: [catalogueItemId], references: [id], onDelete: Cascade)

  @@index([catalogueItemId])
}

// Fan selection / sizing data. Each model has several rating points along a curve.
model FanRatingPoint {
  id                String  @id @default(cuid())
  catalogueItemId   String
  rpm               Int
  airflow_m3hr      Float
  staticPressure_pa Float
  power_kw          Float
  efficiency        Float? // 0..1

  catalogueItem CatalogueItem @relation(fields: [catalogueItemId], references: [id], onDelete: Cascade)

  @@index([catalogueItemId])
}

model Inquiry {
  id          String        @id @default(cuid())
  customerId  String
  source      InquirySource @default(OTHER)
  status      InquiryStatus @default(NEW)
  createdById String
  projectName String?
  notes       String?
  docs        Json          @default("{}") // pre-quotation docs: { inquiry_form: SaleDoc[], rfq_boq: SaleDoc[] }
  createdAt   DateTime      @default(now())

  customer    Customer       @relation(fields: [customerId], references: [id])
  createdBy   User           @relation("InquiryCreatedBy", fields: [createdById], references: [id])
  items       InquiryItem[]
  attachments Attachment[]
  quotations  Quotation[]

  @@index([status])
  @@index([customerId])
}

model InquiryItem {
  id        String            @id @default(cuid())
  inquiryId String
  rawText   String // verbatim of what the client asked for
  // parsedJson: AI-extracted { airflow, airflowUnit, pressure, pressureUnit, qty, application, modelText, ... }
  parsedJson Json             @default("{}")
  qty        Int              @default(1)
  status     InquiryItemStatus @default(PENDING)

  inquiry Inquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  @@index([inquiryId])
}

model Quotation {
  id           String          @id @default(cuid())
  inquiryId    String
  quoteNumber  String          @unique // e.g. 2026 - AFBM00000041J
  templateId   String
  status       QuotationStatus @default(DRAFT)
  // VAT presentation: INCLUSIVE (prices already include 12% VAT) or EXCLUSIVE.
  vatMode      String          @default("INCLUSIVE")
  // Optional discount percentage shown as a "LESS x% DISCOUNT" line.
  discountPct  Decimal         @db.Decimal(5, 2) @default(0)
  // Variable (red) table unit labels: { capacity, pressure, motor }. Defaults cfm / in-w.g. / Hp.
  headerUnits  Json            @default("{}")
  // Product classification from the selection workflow: { category, type, bladeType, drive }.
  classification Json          @default("{}")
  projectName  String?
  subtotal     Decimal         @db.Decimal(14, 2) @default(0)
  vat          Decimal         @db.Decimal(14, 2) @default(0)
  total        Decimal         @db.Decimal(14, 2) @default(0)
  currency     String          @default("PHP")
  validUntil   DateTime?
  preparedById String
  approvedById String?
  notes        String?
  terms        String?
  createdAt    DateTime        @default(now())

  inquiry    Inquiry           @relation(fields: [inquiryId], references: [id])
  template   QuotationTemplate @relation(fields: [templateId], references: [id])
  preparedBy User              @relation("QuotationPreparedBy", fields: [preparedById], references: [id])
  approvedBy User?             @relation("QuotationApprovedBy", fields: [approvedById], references: [id])
  items      QuotationItem[]
  purchaseRequests PurchaseRequest[]
  commission Commission?

  @@index([status])
  @@index([inquiryId])
}

model QuotationItem {
  id                  String   @id @default(cuid())
  quotationId         String
  catalogueItemId     String?
  descriptionSnapshot String
  // specsSnapshot: frozen specs so the quote never changes when the catalogue does
  specsSnapshot       Json     @default("{}")
  qty                 Int      @default(1)
  unitPrice           Decimal  @db.Decimal(14, 2)
  lineTotal           Decimal  @db.Decimal(14, 2)
  selectionNote       String? // why this model/size was chosen
  sortOrder           Int      @default(0)

  quotation     Quotation      @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  catalogueItem CatalogueItem? @relation(fields: [catalogueItemId], references: [id])

  @@index([quotationId])
}

model QuotationTemplate {
  id         String  @id @default(cuid())
  name       String
  layoutKey  String  @unique // e.g. "standard", "government", "detailed", "budgetary", "export"
  headerHtml String?
  footerHtml String?
  config     Json    @default("{}")
  active     Boolean @default(true)

  quotations Quotation[]
}

model Attachment {
  id          String         @id @default(cuid())
  inquiryId   String
  storagePath String
  kind        AttachmentKind @default(OTHER)
  createdAt   DateTime       @default(now())

  inquiry Inquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  @@index([inquiryId])
}

// Sequence helper for per-year quote numbering (AQ-YYYY-NNNN).
model QuoteCounter {
  year      Int @id
  lastValue Int @default(0)
}

/** Generic key/value app settings (e.g. the geofence/location access config). */
model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

/**
 * Purchasing chain for the order-to-delivery workflow (Phase 3, steps 8-13).
 * One row per material request escalated to purchasing. The status walks the
 * approval chain; each step stamps who did it and when.
 */
enum PurchaseRequestStatus {
  PENDING_APPROVAL // purchaser prepared the list, awaiting approver
  REJECTED         // approver rejected
  APPROVED         // dept MRF: Plant-Manager-approved (awaits the Approver's PO approval, recorded in chainLog.approve_po); order-linked: approved, awaiting voucher
  VOUCHER_READY    // accounting prepared voucher + checks, awaiting signing
  VOUCHER_SIGNED   // approver signed check & voucher
  CASH_RELEASED    // approver released cash
  WITH_PURCHASER   // accounting handed cash & check to the purchaser
  CASH_CONFIRMED   // purchaser confirmed receipt of the cash & check
  TASKED           // purchaser handed to logistics head, tasks distributed
  LOGISTICS_CONFIRMED // logistics head confirmed receipt of the cash
  PURCHASED        // bought, awaiting purchaser's item check
  CHECKED          // items checked, awaiting delivery to warehouse
  DELIVERED        // logistics delivered to warehouseman
  RECEIVED         // warehouseman approved the delivery, awaiting plant manager
  PLANT_APPROVED   // plant manager final approval, awaiting receiving into stock
  COMPLETED        // warehouseman received & added to stock
  CANCELLED        // withdrawn by the purchaser before receiving
}

model PurchaseRequest {
  id            String                @id @default(cuid())
  quotationId   String? // null for replenishment (stock top-up, not tied to an order)
  kind          String                @default("order") // "order" | "replenishment"
  stockItemId   String? // for replenishment: the stock item to receive into
  mrfId         String? // the JSON material-request id it was escalated from
  dept          String? // production department key (null for replenishment)
  items         Json                  @default("[]") // ["GI sheet 24ga x 4", ...]
  note          String?
  status        PurchaseRequestStatus @default(PENDING_APPROVAL)
  // Sign-off log for the extended chain steps (sign / release cash / hand to
  // purchaser / assign tasks / deliver) — { stepKey: { byName, at } }.
  chainLog      Json                  @default("{}")
  // Supplier returns: items disapproved on inspection and sent back for
  // replacement — [{ id, items, reason, raisedByName, raisedRole, raisedAt,
  // resolvedByName, resolvedRole, resolvedAt, resolutionNote }]. A PO can't be
  // received into stock while any return is unresolved.
  returns       Json                  @default("[]")
  // Voucher reconciliation: actual cash spent vs the issued voucher (PO total),
  // receipts attached — { voucherAmount, actualSpent, receipts[], recordedByName,
  // recordedAt, settled? }. Auto-tallies so change/overspend is flagged.
  reconciliation Json                 @default("{}")

  createdById   String
  createdByName String
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  // 8 — approver decision
  decidedById   String?
  decidedByName String?
  decisionNote  String?
  decidedAt     DateTime?
  // 9 — voucher / check
  voucherRef    String?
  voucherByName String?
  voucherAt     DateTime?
  // 10 — buying
  purchasedByName String?
  purchasedAt   DateTime?
  // 11 — purchaser item check
  checkedByName String?
  checkedAt     DateTime?
  // 13 — warehouse receive + plant manager final approval
  receivedByName String?
  receivedAt    DateTime?
  plantApprovedByName String?
  plantApprovedAt DateTime?

  // Purchase Order sent to the supplier (number, supplier, priced lines, EWT,
  // remarks). Null until the purchaser issues the PO.
  po            Json?

  quotation Quotation? @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
  @@index([status])
}

enum CashRequestStatus {
  SUBMITTED      // requestor requested money, awaiting accounting to prepare voucher
  REJECTED       // approver rejected the voucher
  VOUCHER_READY  // accounting prepared the voucher, awaiting the approver
  CASH_RELEASED  // approver approved the voucher & released cash (held by accounting)
  DISBURSED      // accounting handed the cash to the requestor
  RECEIVED       // requestor confirmed the cash received
  LIQUIDATED     // requestor liquidated (receipts + actual spend)
  SETTLED        // change returned / overspend reimbursed
  CANCELLED      // withdrawn before the voucher was prepared
}

/**
 * A cash request (cash voucher) — AeroVent's general money-request flow for cash
 * that isn't a supplier material PO (advances, reimbursements, petty cash,
 * expenses). Walks a role-gated chain: request → voucher (accounting) → approve
 * & release cash (approver) → hand to requestor (accounting) → confirm →
 * liquidate. See src/lib/cash-request.ts.
 */
model CashRequest {
  id            String            @id @default(cuid())
  number        String            @unique // CV-<year><seq>
  purpose       String
  category      String            @default("advance") // advance | reimbursement | expense | petty_cash | other
  dept          String? // optional department the cash is for
  amount        Decimal           @db.Decimal(14, 2) // requested / released amount
  lines         Json              @default("[]") // optional breakdown [{ description, amount }]
  status        CashRequestStatus @default(SUBMITTED)

  requestedById   String
  requestedByName String
  note            String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Accounting prepares the voucher.
  voucherRef    String?
  voucherByName String?
  voucherAt     DateTime?
  // Approver decision (approve & release, or reject).
  decidedByName String?
  decisionNote  String?
  decidedAt     DateTime?
  releasedByName String?
  releasedAt    DateTime?
  // Accounting hands the cash to the requestor.
  disbursedByName String?
  disbursedAt   DateTime?
  // Requestor confirms receipt.
  receivedByName String?
  receivedAt    DateTime?
  // Liquidation: actual spend + receipts, change/overspend settlement.
  liquidation   Json              @default("{}")

  @@index([status])
  @@index([requestedById])
}

/**
 * Sales commission (Phase 7). One row per closed order: 1.5% of the order value,
 * credited to the order's salesperson and attributed to the close month.
 * Paid 15 days after that month ends.
 */
model Commission {
  id              String   @id @default(cuid())
  quotationId     String   @unique
  salespersonId   String
  salespersonName String
  orderValue      Decimal  @db.Decimal(14, 2)
  ratePct         Decimal  @db.Decimal(5, 2) @default(1.5)
  amount          Decimal  @db.Decimal(14, 2)
  salesMonth      String // "YYYY-MM" (close month)
  computedAt      DateTime @default(now())
  paid            Boolean  @default(false)
  paidAt          DateTime?
  paidByName      String?

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([salesMonth])
  @@index([salespersonId])
  @@index([paid])
}

/**
 * Manual departmental payroll for the profit-centre P&L. One row per department
 * per month (Manila YYYY-MM); the departmental P&L adds it to that department's
 * expenses. Dept is one of fans | duct | accessories | motor | office.
 */
model Payroll {
  id            String   @id @default(cuid())
  dept          String
  month         String // YYYY-MM (Manila)
  amount        Decimal  @db.Decimal(14, 2) @default(0)
  note          String?
  createdByName String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([dept, month])
  @@index([month])
}

/**
 * Fan-body cost of goods sold for the departmental P&L. A fan line's body COGS
 * is what the Fans department records as its sale; the Office keeps the rest.
 * Looked up by exact model code first (an override), else by size + material.
 * `size` is the blade diameter in inches as a plain string (e.g. "40").
 */
model FanBodyCogs {
  id            String   @id @default(cuid())
  modelCode     String? // exact-match override (e.g. a fan code); null for size/material rows
  size          String? // blade diameter (inches) as a string
  material      String?
  cost          Decimal  @db.Decimal(14, 2) @default(0)
  note          String?
  createdByName String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([modelCode])
  @@index([size, material])
}

/** Warehouse stock. Quantities are decimals so partial units (m, kg) work. */
enum StockMovementKind {
  RECEIPT    // stock in (e.g. purchased items received)
  ISSUE      // stock out (e.g. issued to production)
  ADJUSTMENT // manual correction / opening balance
}

model StockItem {
  id           String   @id @default(cuid())
  sku          String?  @unique // short human/scan code, e.g. "10001"
  name         String
  unit         String   @default("pcs")
  category     String?
  location     String?  // warehouse bin / shelf location
  quantity     Decimal  @db.Decimal(14, 3) @default(0)
  reorderLevel Decimal  @db.Decimal(14, 3) @default(0)
  unitCost     Decimal  @db.Decimal(14, 2) @default(0) // for stock valuation
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  movements    StockMovement[]
  reservations StockReservation[]

  @@index([name])
}

model StockReservation {
  id             String    @id @default(cuid())
  stockItemId    String
  qty            Decimal   @db.Decimal(14, 3)
  forRef         String // what it's reserved for (order no. / job / free text)
  note           String?
  byName         String
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  releasedByName String?
  releasedAt     DateTime?

  stockItem StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  @@index([stockItemId])
  @@index([active])
}

model StockMovement {
  id           String            @id @default(cuid())
  stockItemId  String
  kind         StockMovementKind
  delta        Decimal           @db.Decimal(14, 3)
  balanceAfter Decimal           @db.Decimal(14, 3)
  reason       String?
  byName       String
  createdAt    DateTime          @default(now())

  stockItem StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  @@index([stockItemId])
}

/**
 * Stock transfer between locations with a double-handshake receipt. On send the
 * quantity is issued from the source (in transit); it is received into the
 * destination only once BOTH the production head and the purchaser confirm the
 * receiving location got it. An optional proof (delivery note / photo) is
 * attached and viewable.
 */
enum StockTransferStatus {
  IN_TRANSIT // issued from source, awaiting both receipt confirmations
  RECEIVED   // both confirmed, received into destination
  CANCELLED  // recalled before receipt — quantity returned to source
}

model StockTransfer {
  id              String              @id @default(cuid())
  stockItemId     String? // source stock record (null if later deleted)
  destStockItemId String? // destination stock record (set on receipt)
  itemName        String
  unit            String              @default("pcs")
  qty             Decimal             @db.Decimal(14, 3)
  fromLocation    String
  toLocation      String
  status          StockTransferStatus @default(IN_TRANSIT)
  note            String?
  proof           Json? // { path, name, uploadedAt }
  initiatedById   String
  initiatedByName String
  initiatedAt     DateTime            @default(now())
  // Handshake 1 — production head confirms receipt.
  prodHeadById    String?
  prodHeadByName  String?
  prodHeadAt      DateTime?
  // Handshake 2 — purchaser confirms receipt.
  purchaserById   String?
  purchaserByName String?
  purchaserAt     DateTime?
  receivedAt      DateTime?
  cancelledByName String?
  cancelledAt     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([status])
}

/**
 * Purchasable product/item catalogue, connected to suppliers. Each product may
 * be sourced from several suppliers (each with its own code and price), stored
 * as JSON since suppliers live in the AppSetting directory (no supplier table).
 * Mirrors StockItem's SKU + barcode/QR encoding features.
 */
model Product {
  id        String   @id @default(cuid())
  sku       String?  @unique // short human/scan code, e.g. "PRD10001"
  name      String
  unit      String   @default("pcs")
  category  String?
  note      String?
  suppliers Json     @default("[]") // [{ supplierId, company, code, price }]
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

enum ScheduleStatus {
  PENDING
  APPROVED
  REJECTED
}

/**
 * Shared team calendar. Any user may add a schedule (starts PENDING); an
 * Engineer, Admin or Approver approves or rejects it. Times are stored in UTC;
 * an all-day entry uses startAt at 00:00 of the day.
 */
model Schedule {
  id            String         @id @default(cuid())
  title         String
  details       String?
  category      String         @default("general") // general | meeting | delivery | production | payment | maintenance | other
  startAt       DateTime
  endAt         DateTime?
  allDay        Boolean        @default(true)
  location      String?
  status        ScheduleStatus @default(PENDING)
  createdById   String
  createdByName String
  decidedById   String?
  decidedByName String?
  decidedAt     DateTime?
  decisionNote  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([startAt])
  @@index([status])
}
